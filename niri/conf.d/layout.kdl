layout {
    gaps 0
    center-focused-column "on-overflow"
    background-color "transparent"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    focus-ring {
        width 0
        active-color "#1E1E2E"
    }

    insert-hint {
        off
        color "#1E1E2E"
    }

    struts {}
}
