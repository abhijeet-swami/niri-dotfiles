{
  "group/extras": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "extras",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/menu",
      "tray"
    ]
  },

  "group/brightness": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "brightness",
      "transition-left-to-right": false
    },
    "modules": [
      "backlight",
      "backlight/slider"
    ]
  },

  "group/audio": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 400,
      "children-class": "audio",
      "transition-left-to-right": false
    },
    "modules": [
      "pulseaudio",
      "pulseaudio/slider"
    ]
  },

  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "у∞Д∞",
      "active": "у∞Дѓ"
    }
  },

  "cpu": {
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>в†Б</span>",
      "<span size='14pt'>в†Й</span>",
      "<span size='14pt'>в†Щ</span>",
      "<span size='14pt'>в†Ы</span>",
      "<span size='14pt'>в†Я</span>",
      "<span size='14pt'>в†њ</span>"
    ],
    "interval": 1,
    "tooltip": true,
    "tooltip-format": "CPU Frequency: {avg_frequency} GHz",
    "on-click": "kitty -e btop"
  },

  "clock": {
    "interval": 1,
    "format": "{:%H\n%M}",
    "format-alt": "{:%d\n%m\n%y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },

  "mpris": {
    "format": "<span size='14pt'>у∞РО</span>",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": true,
    "tooltip-format": "{title}"
  },

  "custom/menu": {
    "format": "<span size='16pt'>у∞ЕГ</span>",
    "tooltip": false
  },

  "tray": {
    "spacing": 16,
    "reverse-direction": true,
    "icon-size": 16,
    "show-passive-items": false
  },

  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": false
      }
    ],
    "ignore": [
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },

  "network": {
    "format-icons": {
      "wifi": [
        "<span size='12pt'>у∞§ѓ</span>",
        "<span size='12pt'>у∞§Я</span>",
        "<span size='12pt'>у∞§Ґ</span>",
        "<span size='12pt'>у∞§•</span>",
        "<span size='12pt'>у∞§®</span>"
      ],
      "ethernet": "<span size='12pt'>у∞ИА</span>",
      "disabled": "<span size='12pt'>у∞§≠</span>",
      "disconnected": "<span size='12pt'>у∞§©</span>"
    },
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon}",
    "format-disabled": "{icon}",
    "interval": 5,
    "tooltip-format": "{essid}\t{gwaddr}",
    "on-click": "kitty -e impala",
    "on-click-right": "kitty -e impala",
    "tooltip": true,
    "max-length": 20
  },

  "bluetooth": {
    "interval": 5,
    "format-on": "<span size='14pt'>у∞Вѓ</span>",
    "format-off": "<span size='14pt'>у∞В≤</span>",
    "format-disabled": "<span size='14pt'>у∞В≤</span>",
    "format-connected": "<span size='14pt'>у∞В±</span>",
    "format-no-controller": "<span size='14pt'>у∞Вѓ</span>",
    "tooltip": true,
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_address} | Battery: {device_battery_percentage}%",
    "on-click": "kitty -e bluetui",
    "on-click-right": "kitty -e bluetui"
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "<span size='14pt'>у∞Нђ</span>",
    "format-source-muted": "<span size='14pt'>у∞Н≠</span>",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip": false
  },

  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical"
  },

  "pulseaudio": {
    "interval": 1,
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>у∞Хњ</span>",
      "<span size='14pt'>у∞ЦА</span>",
      "<span size='14pt'>у∞ХЊ</span>"
    ],
    "format-muted": "<span size='14pt'>у∞ЭЯ</span>",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol -t 3",
    "reverse-scrolling": true,
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%\n{desc}",
    "ignored-sinks": [
      "Easy Effects Sink"
    ]
  },

  "backlight/slider": {
    "min": 0,
    "max": 100,
    "orientation": "vertical",
    "device": "intel_backlight"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": [
      "у∞ГЪ", "у∞ГЫ", "у∞ГЬ", "у∞ГЭ", "у∞ГЮ", "у∞ГЯ", "у∞Г†"
    ],
    "reverse-scrolling": true,
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },

  "battery": {
    "interval": 5,
    "states": {
      "critical": 10
    },
    "format": "{icon}",
    "format-icons": [
      "<span size='14pt'>у∞БЇ</span>",
      "<span size='14pt'>у∞Бї</span>",
      "<span size='14pt'>у∞БЉ</span>",
      "<span size='14pt'>у∞Бљ</span>",
      "<span size='14pt'>у∞БЊ</span>",
      "<span size='14pt'>у∞Бњ</span>",
      "<span size='14pt'>у∞ВА</span>",
      "<span size='14pt'>у∞ВБ</span>",
      "<span size='14pt'>у∞ВВ</span>",
      "<span size='14pt'>у∞Бє</span>"
    ],
    "format-charging": "<span size='14pt'>у∞ВД</span>",
    "format-plugged": "<span size='14pt'>у∞Ъ•</span>",
    "format-critical": "<span size='14pt'>у∞ВГ</span>",
    "tooltip": true,
    "tooltip-format": "Charge: {capacity}%",
    "tooltip-format-charging": "Charging: {capacity}%"
  },

  "custom/powermenu": {
    "format": "<span size='13pt'>у∞Р•</span>",
    "on-click": "$HOME/.config/bin/powermenu.sh",
    "tooltip": false
  },

  "custom/terminal": {
    "format": "пМГ",
    "tooltip": false,
    "on-click": "kitty",
  },
}
